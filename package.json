		"carbon-components-svelte": "^0.62.1",
		"carbon-icons-svelte": "^10.45.1",
		"carbon-preprocess-svelte": "^0.7.0",
		"eslint": "^8.11.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte3": "^3.4.1",
		"mdsvex": "^0.10.5",
		"prettier": "^2.6.0",
