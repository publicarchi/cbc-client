{
	"extends": "./.svelte-kit/tsconfig.json",

	"compilerOptions": {
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports" :true, 
		"paths": {
			"$lib": [
				"src/lib"
			],
			"$lib/*": [
				"src/lib/*"
			],
			"$components": [
				"src/components/index.ts"
			],
			"$helpers": [
				"src/lib/helpers/index.ts"
			],
			"$stores": [
				"src/stores/index.ts"
			]
		}
	}
}
